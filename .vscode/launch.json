{
  "version": "0.2.0",
  // ─────────────────────────────────────────────────────────────────────────────
  // web_lib – VSCode debugger launch configurations
  //
  // HOW TO RUN THE GAME:
  //   Use the Tasks panel (Ctrl+Shift+P → "Tasks: Run Task") or the keyboard
  //   shortcuts defined in tasks.json:
  //     • Run NeoForge Client  →  ./gradlew :neoforge:runClient
  //     • Run Fabric Client    →  ./gradlew :fabric:runClient
  //
  // HOW TO DEBUG:
  //   1. Start the client via a **(Debug)** task below in tasks.json.
  //      That task appends --debug-jvm which opens a JDWP socket on port 5005/5006.
  //   2. Then press F5 (or click ▷) on the matching "Attach Debugger" entry below.
  //
  // ─────────────────────────────────────────────────────────────────────────────
  "configurations": [
    {
      "type": "java",
      "request": "attach",
      "name": "Attach Debugger – NeoForge Client",
      "hostName": "localhost",
      "port": 5005,
      "presentation": {
        "group": "Web Lib – Attach Debugger",
        "order": 0
      }
    },
    {
      "type": "java",
      "request": "attach",
      "name": "Attach Debugger – Fabric Client",
      "hostName": "localhost",
      "port": 5006,
      "presentation": {
        "group": "Web Lib – Attach Debugger",
        "order": 1
      }
    }
  ]
}
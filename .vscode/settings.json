{
  // ── Java ──────────────────────────────────────────────────────────────────
  // Use the Gradle build scripts to discover source sets instead of scanning
  // the whole workspace – this is required for the multi-module layout.
  "java.import.gradle.enabled": true,
  "java.import.gradle.wrapper.enabled": true,
  // Exclude generated/downloaded directories from the Java language server so
  // it doesn't spend time analysing Minecraft internals or Gradle caches.
  "java.project.referencedLibraries": {
    "exclude": [
      "build/**",
      ".gradle/**",
      "common/build/**",
      "neoforge/build/**",
      "fabric/build/**"
    ]
  },

  // ── Gradle ────────────────────────────────────────────────────────────────
  // Point the Gradle extension at the root wrapper so it picks up all subprojects.
  "gradle.gradlePath": "${workspaceFolder}/gradlew",
  "gradle.reuseTerminals": "task",

  // ── Files: hide generated/build artefacts from the explorer ──────────────
  "files.exclude": {
    "**/.gradle": true,
    "**/build": true,
    "**/run": true,
    "**/runs": true
  },

  // ── Editor ────────────────────────────────────────────────────────────────
  "[java]": {
    "editor.formatOnSave": false,
    "editor.tabSize": 4
  }
}
